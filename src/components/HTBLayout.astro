---
interface Props {
	title: string;
	os: string;
	difficulty: string;
	pwnedDate: string;
	avatar: string;
	status?: string;
	id?: string;
	headings?: { depth: number; text: string; id: string }[];
	description?: string;
}

const { title, os, difficulty, pwnedDate, avatar, status = "PWNED", id = "", headings = [], description = "" } = Astro.props;
import GlobalEffects from './GlobalEffects.astro';
import { Image } from 'astro:assets';
import machinesData from '../data/machines.json';
import bimpsonBrand from '../assets/images/Bimpson_face.jpeg';

const difficultyColor: Record<string, string> = {
    Easy:   '#9acd32',
    Medium: '#f39c12',
    Hard:   '#e74c3c',
    Insane: '#ffffff',
};

const diffColor = difficultyColor[difficulty] || '#9acd32';

// Status colors
const statusColors: Record<string, { bg: string, text: string }> = {
    "PWNED":      { bg: "#9acd32", text: "#000" },
    "USER PWNED": { bg: "#f39c12", text: "#000" },
    "NOT PWNED":  { bg: "#3e444d", text: "#fff" }
};

const currentStatus = statusColors[status] || statusColors["PWNED"];

// Prepare data for the Left Sidebar navigation
const difficultiesLevels = ["Easy", "Medium", "Hard", "Insane"];
const groupedMachines: Record<string, Record<string, any[]>> = {};

difficultiesLevels.forEach(d => {
    groupedMachines[d] = { Linux: [], Windows: [], MacOS: [] };
});

machinesData.forEach(m => {
    if (groupedMachines[m.difficulty] && groupedMachines[m.difficulty][m.os]) {
        groupedMachines[m.difficulty][m.os].push(m);
    }
});
---

<html lang="pt">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title} | HTB Pwned</title>
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@800&family=Inter:wght@400;700&display=swap');

			body {
				margin: 0;
				background-color: #131313;
				color: #fff;
				font-family: 'JetBrains Mono', monospace;
				line-height: 1.6;
				overflow-x: hidden;
                cursor: none;
			}
            
            /* Custom Scrollbar */
            ::-webkit-scrollbar { width: 8px; }
            ::-webkit-scrollbar-track { background: #131313; }
            ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }
            ::-webkit-scrollbar-thumb:hover { background: rgba(154, 205, 50, 0.5); }

			.layout-wrapper {
				display: grid;
				grid-template-columns: 280px 1fr 280px;
				gap: 40px;
				max-width: 1700px;
				margin: 0 auto;
				padding: 80px 2vw;
				align-items: stretch;
			}

			/* --- LEFT SIDEBAR (Base/Desktop) --- */
			.left-sidebar {
				position: sticky;
				top: 90px;
				height: calc(100vh - 90px);
				overflow-y: auto;
				padding: 0 15px 40px 0;
				border-right: 1px solid rgba(255,255,255,0.05);
				box-sizing: border-box;
			}

			@media (max-width: 1300px) {
				.layout-wrapper {
					grid-template-columns: 260px 1fr;
				}
				.right-sidebar { display: none !important; }
				
			}

			@media (max-width: 900px) {
				.layout-wrapper {
					grid-template-columns: 1fr;
					padding: 60px 4vw;
				}
				.left-sidebar {
					position: fixed !important;
					top: 80;
					left: 0;
					width: 300px;
					height: 100vh;
					max-height: 100vh;
					background: #131313;
					border-right: 1px solid rgba(255,255,255,0.08);
					border-top: 2px solid var(--diff-color);
					z-index: 5000;
					transform: translateX(-110%);
					transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
					padding: 40px 15px 40px 20px;
					overflow-y: auto;
					box-sizing: border-box;
				}
				.left-sidebar.open {
					transform: translateX(0);
				}
			}

			/* Hamburger button (mobile only) */
			.hamburger-btn {
				display: none;
				position: fixed;
				top: 16px;
				left: 16px;
				z-index: 6000;
				background: rgba(10,10,10,0.9);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 6px;
				width: 40px;
				height: 40px;
				cursor: pointer;
				align-items: center;
				justify-content: center;
				flexDirection: column;
				gap: 5px;
				padding: 0;
				backdrop-filter: blur(8px);
				transition: border-color 0.2s;
			}

			.hamburger-btn:hover {
				border-color: var(--diff-color);
			}

			.hamburger-btn span {
				display: block;
				width: 18px;
				height: 2px;
				background: #fff;
				border-radius: 2px;
				transition: all 0.3s ease;
				transform-origin: center;
			}

			.hamburger-btn.open span:nth-child(1) {
				transform: translateY(7px) rotate(45deg);
			}
			.hamburger-btn.open span:nth-child(2) {
				opacity: 0;
				transform: scaleX(0);
			}
			.hamburger-btn.open span:nth-child(3) {
				transform: translateY(-7px) rotate(-45deg);
			}

			@media (max-width: 900px) {
				.hamburger-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }
			}

			/* Drawer overlay */
			.drawer-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.6);
				z-index: 4999;
				backdrop-filter: blur(2px);
				opacity: 0;
				transition: opacity 0.35s ease;
			}

			.drawer-overlay.open {
				display: block;
				opacity: 1;
			}


			.sidebar-brand {
			    display: flex;
			    align-items: center;
			    gap: 12px;
			    margin-bottom: 30px;
			    padding: 12px;
			    border-radius: 8px;
			    background: rgba(255,255,255,0.03);
			    border: 1px solid rgba(255,255,255,0.06);
			    text-decoration: none;
			    transition: background 0.2s;
			}

			.sidebar-brand:hover {
			    background: rgba(255,255,255,0.06);
			}

			.sidebar-brand-avatar {
			    width: 36px;
			    height: 36px;
			    border-radius: 50%;
			    object-fit: cover;
			    border: 1px solid var(--diff-color);
			    flex-shrink: 0;
			}

			.sidebar-brand-name {
			    font-family: 'Syne', sans-serif;
			    font-weight: 800;
			    font-size: 0.9rem;
			    color: #fff;
			    letter-spacing: 0.02em;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				flex: 1;
				min-width: 0;
			}

			.sidebar-section {
			    margin-bottom: 20px;
			}

			.sidebar-header-title {
			    font-size: 0.65rem;
			    letter-spacing: 0.15em;
			    text-transform: uppercase;
			    color: rgba(255,255,255,0.4);
			    margin-bottom: 15px;
			}

			details {
			    margin-bottom: 5px;
			}

			summary {
			    cursor: pointer;
			    font-size: 0.75rem;
			    letter-spacing: 0.1em;
			    padding: 8px 10px;
			    border-radius: 4px;
			    transition: all 0.2s;
			    color: rgba(255,255,255,0.8);
			    display: flex;
			    align-items: center;
			    gap: 8px;
			    list-style: none; /* remove default arrow */
			}
			
			summary::-webkit-details-marker {
				display: none;
			}

			summary::before {
				content: "▸";
				font-size: 0.8rem;
				transition: transform 0.2s;
				color: rgba(255,255,255,0.4);
			}

			details[open] > summary::before {
				transform: rotate(90deg);
			}

			summary:hover {
			    background: rgba(255,255,255,0.05);
			    color: #fff;
			}

			details[open] > summary {
			    color: #fff;
			}

			.nav-group ul {
			    list-style: none;
			    padding-left: 15px;
			    margin: 5px 0 10px 0;
			    border-left: 1px solid rgba(255,255,255,0.1);
			}

			.nav-link {
			    display: flex;
			    align-items: center;
			    gap: 10px;
			    text-decoration: none;
			    color: rgba(255,255,255,0.6);
			    font-size: 0.75rem;
			    padding: 8px 10px;
			    border-radius: 4px;
			    transition: all 0.2s;
			}
			
			.nav-link::before {
			    content: "■";
			    font-size: 0.5rem;
			    color: rgba(255,255,255,0.2);
			}

			.nav-link:hover {
			    color: #fff;
			}

			.nav-link.active {
			    color: var(--diff-color);
			    background: rgba(154, 205, 50, 0.05); /* very light tint */
			}
			
			.nav-link.active::before {
				color: var(--diff-color);
			}


			/* --- MAIN CONTENT --- */
			.main-content {
				min-width: 0; /* Prevents overflow in grid */
			}

			.back-link {
				color: #9acd32;
				text-decoration: none;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				margin-bottom: 30px;
				display: inline-block;
				transition: all 0.3s;
			}

			.back-link:hover {
				opacity: 0.7;
				transform: translateX(-5px);
			}

			.content-banner {
				display: flex;
				align-items: center;
				gap: 40px;
				margin-bottom: 25px;
				background: rgba(255, 255, 255, 0.02);
				padding: 40px 50px;
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: 8px;
                position: relative;
                overflow: hidden;
			}
            
            .content-banner::before {
                content: "";
                position: absolute;
                top: 0; left: 0; width: 4px; height: 100%;
                background: var(--diff-color);
            }

            /* Circular background effect behind avatar */
            .banner-avatar-wrapper {
                position: relative;
                flex-shrink: 0;
                width: 120px;
                height: 120px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            @keyframes sonar-inner {
                0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 0.4; }
                50%        { transform: translate(-50%, -50%) scale(1.08); opacity: 0.2; }
            }
            @keyframes sonar-outer {
                0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 0.2; }
                50%        { transform: translate(-50%, -50%) scale(1.06); opacity: 0.08; }
            }

            .banner-avatar-wrapper::after {
            	content: "";
            	position: absolute;
            	top: 50%; left: 50%;
                transform: translate(-50%, -50%);
            	width: 130%; height: 130%;
            	border: 1px solid var(--diff-color);
            	border-radius: 50%;
            	animation: sonar-inner 3s ease-in-out infinite;
            }
            .banner-avatar-wrapper::before {
            	content: "";
            	position: absolute;
            	top: 50%; left: 50%;
                transform: translate(-50%, -50%);
            	width: 160%; height: 160%;
            	border: 1px solid var(--diff-color);
            	border-radius: 50%;
            	animation: sonar-outer 3s ease-in-out infinite 0.4s;
            }

			.avatar {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				border: 2px solid var(--diff-color);
				padding: 5px;
                background: #131313;
                position: relative;
                z-index: 2;
			}

			.banner-info {
				display: flex;
				flex-direction: column;
				gap: 8px;
			}
			
			.retired-label {
				font-size: 0.65rem;
				letter-spacing: 0.2em;
				color: rgba(255,255,255,0.6);
			}

			.banner-info h1 {
				font-family: 'Syne', sans-serif;
				font-size: clamp(2rem, 5vw, 4.2rem);
				margin: 0;
				line-height: 1;
				text-transform: uppercase;
				white-space: nowrap;
			}

			.banner-meta {
				display: flex;
                gap: 20px;
				margin-top: 10px;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
			}
			
			.banner-meta span {
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.banner-meta i {
				color: rgba(255,255,255,0.4);
			}

			.htb-machine-meta {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.7rem;
				opacity: 0.6;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-top: 15px;
				display: flex;
				gap: 15px;
			}

			.htb-machine-meta b {
				color: #9acd32;
			}

            @media (max-width: 768px) {
                .content-banner {
                    flex-direction: column;
                    text-align: center;
                    padding: 60px 20px 40px;
                    gap: 50px;
                }
                .banner-info {
                    width: 100%;
                    padding: 0 15px;
                    box-sizing: border-box;
                }
                .banner-info h1 {
                    font-size: clamp(0.8rem, 6.5vw, 1.8rem);
                    white-space: nowrap;
                    display: block;
                    width: 100%;
                }
                .banner-meta {
                    justify-content: center;
                }
            }

            .content-divider {
                width: 100%;
                height: 1px;
                background: rgba(255, 255, 255, 0.1);
                margin: 0 0 40px 0;
            }


			/* --- RIGHT SIDEBAR --- */
			.right-sidebar {
				position: sticky;
				top: 90px;
				height: calc(100vh - 90px);
				overflow-y: auto;
				padding: 0 0 40px 15px;
				border-left: 1px solid rgba(255,255,255,0.05);
				box-sizing: border-box;
			}
			
			.toc-header {
				font-size: 0.65rem;
				letter-spacing: 0.15em;
				color: rgba(255,255,255,0.5);
				text-transform: uppercase;
				margin-bottom: 20px;
			}
			
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			
			.toc-list li {
				margin-bottom: 10px;
			}
			
			.toc-list a {
				text-decoration: none;
				color: rgba(255,255,255,0.5);
				font-size: 0.75rem;
				transition: all 0.2s;
				display: block;
			}
			
			.toc-list a:hover, .toc-list a.active {
				color: var(--diff-color);
			}

			.toc-h1 { font-family: 'Syne', sans-serif; margin-top: 15px; }
			.toc-h2 { padding-left: 5px; }
			.toc-h3 { padding-left: 15px; font-size: 0.7rem !important; }
			.toc-h4 { padding-left: 25px; font-size: 0.65rem !important; }

			/* Markdown Styling - Scoped to .writeup-content */
			.writeup-content {
				font-size: 1.05rem;
				line-height: 1.8;
                max-width: 100%;
                color: rgba(255, 255, 255, 0.9);
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
			}

            .writeup-content > * {
                margin-bottom: 25px;
            }

			.writeup-content h1, .writeup-content h2, .writeup-content h3 {
				font-family: 'Syne', sans-serif;
				color: #fff;
				text-transform: uppercase;
				scroll-margin-top: 100px; /* Offset for sticky headers if any */
			}

			.writeup-content h1 {
				font-size: 2.2rem;
				margin: 60px 0 25px;
				letter-spacing: -0.01em;
			}

			.writeup-content h2 {
				font-size: 1.6rem;
				margin: 50px 0 20px;
				border-bottom: 1px solid rgba(255,255,255,0.1);
				padding-bottom: 10px;
			}

            .writeup-content h3 {
				font-size: 1.2rem;
				margin: 40px 0 15px;
				color: #9acd32;
			}

			.writeup-content p { 
                opacity: 0.9;
                line-height: 1.7;
            }

            .writeup-content a {
                color: #9acd32;
                text-decoration: none;
                border-bottom: 1px solid rgba(154, 205, 50, 0.3);
                transition: border 0.2s;
            }

            .writeup-content a:hover {
                border-bottom-color: #9acd32;
            }

			.writeup-content pre {
				background: #0d1117 !important;
				padding: 24px;
				border-radius: 8px;
				border: 1px solid rgba(255, 255, 255, 0.1);
				margin: 30px 0;
				overflow-x: auto;
                box-shadow: inset 0 1px 10px rgba(0,0,0,0.3);
                transition: max-height 0.4s ease-out;
                
                scrollbar-width: auto;
                scrollbar-color: #9acd32 rgba(255, 255, 255, 0.05);
			}

            .code-block-wrapper {
                position: relative;
                margin: 30px 0;
            }

            .code-block-wrapper.collapsed pre {
                max-height: 350px;
                overflow: hidden;
                padding-bottom: 60px;
            }

            .code-block-wrapper .expand-btn {
                display: none;
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                background: linear-gradient(transparent, #0d1117 60%, #0d1117);
                color: #9acd32;
                border: none;
                padding: 40px 0 15px;
                cursor: pointer;
                font-family: 'JetBrains Mono', monospace;
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.2em;
                z-index: 10;
                border-radius: 0 0 8px 8px;
                transition: color 0.2s;
            }

            .code-block-wrapper.collapsed .expand-btn {
                display: block;
            }

            .code-block-wrapper .expand-btn:hover {
                color: #fff;
            }

            .writeup-content pre code {
                font-weight: 400;
                color: #e6edf3;
            }

            .writeup-content pre::-webkit-scrollbar { height: 10px; }
            .writeup-content pre::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.05); border-radius: 0 0 8px 8px; }
            .writeup-content pre::-webkit-scrollbar-thumb { background: rgba(154, 205, 50, 0.5); border-radius: 10px; border: 1px solid #0d1117; }
            .writeup-content pre:hover::-webkit-scrollbar-thumb { background: #9acd32; }

			.writeup-content code {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.9rem;
				color: #e6edf3;
                background: rgba(255, 255, 255, 0.1);
                padding: 3px 6px;
                border-radius: 4px;
                word-break: break-all;
			}

            .writeup-content pre code {
                color: inherit;
                background: none;
                padding: 0;
                white-space: pre; 
                word-break: normal;
                font-size: 0.85rem;
            }

            .writeup-content strong {
                color: #fff;
                font-weight: 700;
            }

            .writeup-content ul, .writeup-content ol {
                padding-left: 25px;
            }

            .writeup-content li {
                margin-bottom: 10px;
            }

            .writeup-content blockquote {
                border-left: 4px solid #30363d;
                padding: 15px 25px;
				color: #8b949e;
                background: rgba(48, 54, 61, 0.1);
                margin: 30px 0;
            }

            .writeup-content img {
                border: 1px solid #30363d;
                max-width: 100%;
				border-radius: 4px;
				margin: 40px 0;
                cursor: pointer;
                transition: transform 0.2s ease;
            }

            .writeup-content img:hover {
                transform: scale(1.01);
                border-color: var(--diff-color);
            }

            /* --- LIGHTBOX --- */
            .lightbox-overlay {
                position: fixed;
                inset: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0, 0, 0, 0.95);
                display: none;
                justify-content: center;
                align-items: center;
                z-index: 10000;
                cursor: zoom-out;
                opacity: 0;
                transition: opacity 0.3s ease;
                padding: 20px;
                backdrop-filter: blur(8px);
                box-sizing: border-box;
            }

            .lightbox-overlay.active {
                display: flex;
                opacity: 1;
            }

            .lightbox-image {
                max-width: 95%;
                max-height: 95%;
                object-fit: contain;
                border-radius: 4px;
                box-shadow: 0 0 50px rgba(0,0,0,0.5);
                transform: scale(0.9);
                transition: transform 0.3s ease;
            }

            .lightbox-overlay.active .lightbox-image {
                transform: scale(1);
            }

            .lightbox-close {
                position: absolute;
                top: 20px;
                right: 30px;
                color: #fff;
                font-size: 3rem;
                cursor: pointer;
                font-family: 'Syne', sans-serif;
                opacity: 0.5;
                transition: opacity 0.2s;
            }

            .lightbox-close:hover {
                opacity: 1;
                color: var(--diff-color);
            }

			.diff-badge {
				display: inline-block;
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.6rem;
				padding: 2px 8px;
				border-radius: 2px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
                border: 1px solid;
			}

			.status-badge {
				background: var(--status-bg);
				color: var(--status-text);
				padding: 4px 12px;
				font-size: 0.65rem;
				font-weight: 800;
				border-radius: 4px;
				vertical-align: middle;
				margin-left: 15px;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                display: inline-block;
			}
		</style>
	</head>
	<body style={`--diff-color: ${diffColor}; --status-bg: ${currentStatus.bg}; --status-text: ${currentStatus.text};`}>
		<GlobalEffects />

		<!-- Mobile Hamburger Button -->
		<button class="hamburger-btn" id="hamburger-btn" aria-label="Open Navigation">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<!-- Drawer Overlay -->
		<div class="drawer-overlay" id="drawer-overlay"></div>
		
		<div class="layout-wrapper">
			<!-- Left Sidebar Navigation -->
			<aside class="left-sidebar">
				<a href="/" class="sidebar-brand">
					<Image src={bimpsonBrand} alt="DiogoCoutoooo" class="sidebar-brand-avatar" />
					<span class="sidebar-brand-name">DiogoCoutoooo</span>
				</a>
				<div class="sidebar-section">
					<div class="sidebar-header-title">HACK THE BOX - WRITEUPS</div>
					<nav class="nav-group">
						<details open>
							<summary>HTB - MACHINES</summary>
							<ul>
								{difficultiesLevels.map(diff => (
									<details open={difficulty === diff}>
										<summary>{diff.toUpperCase()}</summary>
										<ul>
											{['Linux', 'Windows', 'MacOS'].map(osName => (
												groupedMachines[diff][osName] && groupedMachines[diff][osName].length > 0 && (
													<details open={difficulty === diff && os === osName}>
														<summary>{osName.toUpperCase()}</summary>
														<ul>
															{groupedMachines[diff][osName].map(m => (
																<li>
																	<a href={`/htb/${m.id}`} class={`nav-link ${id === m.id ? "active" : ""}`}>
																		HTB-{m.title.toUpperCase()}{m.status === 'USER PWNED' ? '(VL)' : ''}
																	</a>
																</li>
															))}
														</ul>
													</details>
												)
											))}
										</ul>
									</details>
								))}
							</ul>
						</details>
					</nav>
				</div>
			</aside>

			<!-- Main Content -->
			<main class="main-content">
				<a href="/htb" class="back-link">← Security_Archive</a>
				
				<header class="content-banner">
					<div class="banner-avatar-wrapper">
						<Image src={avatar} alt={title} class="avatar" width={120} height={120} />
					</div>
					<div class="banner-info">
						<h1>{title}</h1>
						<div class="banner-meta" style="margin-top: 15px; gap: 8px; align-items: center; justify-content: flex-start;">
							<span class="diff-badge" style={`color: ${diffColor}; border-color: ${diffColor}; background: ${diffColor}18`}>
								{difficulty}
							</span>
							<span class="diff-badge" style="color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.05);">
								{os}
							</span>
							{status && (
								<span class="status-badge" style="margin-left: 0; padding: 2px 8px; font-size: 0.6rem; border-radius: 2px;">
									{status}
								</span>
							)}
						</div>

						<div class="htb-machine-meta">
							<span><b>PWNED:</b> {pwnedDate}</span>
						</div>
					</div>
				</header>

                <div class="content-divider"></div>

				<article class="writeup-content">
					<slot />
				</article>
			</main>

			<!-- Right Sidebar Table of Contents -->
			<aside class="right-sidebar">
				<ul class="toc-list">
					{headings.length > 0 ? headings.map(h => (
						<li class={`toc-h${h.depth}`}>
							<a href={`#${h.id}`}>{h.text}</a>
						</li>
					)) : (
						<li style="list-style: none; padding: 0;">
							<p style="color: rgba(255,255,255,0.5); font-size: 0.82rem; line-height: 1.7; margin: 0; text-align: justify;">{description}</p>
						</li>
					)}
				</ul>
			</aside>
		</div>

        <!-- Image Lightbox Modal -->
        <div id="lightbox" class="lightbox-overlay">
            <span class="lightbox-close">&times;</span>
            <img src="" alt="Full Screen image" class="lightbox-image" id="lightbox-img" />
        </div>

        <script>
            function setupCollapsibleCode() {
                const codeBlocks = document.querySelectorAll('.writeup-content pre');
                const MAX_HEIGHT = 350;

                codeBlocks.forEach(pre => {
                    if (pre.parentElement?.classList.contains('code-block-wrapper')) return;

                    if (pre.scrollHeight > MAX_HEIGHT + 50) {
                        const wrapper = document.createElement('div');
                        wrapper.className = 'code-block-wrapper collapsed';
                        
                        const expandBtn = document.createElement('button');
                        expandBtn.className = 'expand-btn';
                        expandBtn.innerText = '↓ View Full Output [Click to Expand]';
                        
                        pre.parentNode?.insertBefore(wrapper, pre);
                        wrapper.appendChild(pre);
                        wrapper.appendChild(expandBtn);

                        expandBtn.addEventListener('click', () => {
                            const isCollapsed = wrapper.classList.contains('collapsed');
                            if (isCollapsed) {
                                wrapper.classList.remove('collapsed');
                                expandBtn.innerText = '↑ Collapse Output';
                            } else {
                                wrapper.classList.add('collapsed');
                                expandBtn.innerText = '↓ View Full Output [Click to Expand]';
                                wrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                            }
                        });
                    }
                });
            }

            function setupTocHighlighting() {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const id = entry.target.id;
                            document.querySelectorAll('.toc-list a').forEach(a => {
                                a.classList.remove('active');
                                if (a.getAttribute('href') === `#${id}`) {
                                    a.classList.add('active');
                                }
                            });
                        }
                    });
                }, { rootMargin: '-10% 0px -80% 0px' });

                document.querySelectorAll('.writeup-content h1, .writeup-content h2, .writeup-content h3, .writeup-content h4').forEach(h => {
                    if (h.id) observer.observe(h);
                });
            }

            function setupImageLightbox() {
                const images = document.querySelectorAll('.writeup-content img');
                const lightbox = document.getElementById('lightbox');
                const lightboxImg = document.getElementById('lightbox-img');
                const lightboxClose = document.querySelector('.lightbox-close');

                if (!lightbox || !lightboxImg) return;

                images.forEach(img => {
                    img.addEventListener('click', () => {
                        const src = img.getAttribute('src');
                        if (src) {
                            lightboxImg.setAttribute('src', src);
                            lightbox.classList.add('active');
                            document.body.style.overflow = 'hidden'; // Prevent scroll
                        }
                    });
                });

                const closeLightbox = () => {
                    lightbox.classList.remove('active');
                    document.body.style.overflow = '';
                    setTimeout(() => {
                        lightboxImg.setAttribute('src', '');
                    }, 300);
                };

                lightbox.addEventListener('click', closeLightbox);
                lightboxClose?.addEventListener('click', (e) => {
                    e.stopPropagation();
                    closeLightbox();
                });

                // Escape key support
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') closeLightbox();
                });
            }

            function setupMobileDrawer() {
                const btn = document.getElementById('hamburger-btn');
                const overlay = document.getElementById('drawer-overlay');
                const sidebar = document.querySelector('.left-sidebar');

                if (!btn || !overlay || !sidebar) return;

                const openDrawer = () => {
                    btn.classList.add('open');
                    overlay.classList.add('open');
                    sidebar.classList.add('open');
                    document.body.style.overflow = 'hidden';
                };

                const closeDrawer = () => {
                    btn.classList.remove('open');
                    overlay.classList.remove('open');
                    sidebar.classList.remove('open');
                    document.body.style.overflow = '';
                };

                btn.addEventListener('click', () => {
                    if (sidebar.classList.contains('open')) closeDrawer();
                    else openDrawer();
                });

                overlay.addEventListener('click', closeDrawer);

                // Close drawer when a nav link is clicked
                sidebar.querySelectorAll('.nav-link').forEach(link => {
                    link.addEventListener('click', closeDrawer);
                });

                // Close on Escape
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') closeDrawer();
                });
            }

            setupCollapsibleCode();
            setupTocHighlighting();
            setupImageLightbox();
            setupMobileDrawer();

            document.addEventListener('astro:page-load', () => {
                setupCollapsibleCode();
                setupTocHighlighting();
                setupImageLightbox();
                setupMobileDrawer();
            });
        </script>
	</body>
</html>