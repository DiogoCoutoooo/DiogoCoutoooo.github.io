---
import HTBLayout from '../../components/HTBLayout.astro';
import machinesData from '../../data/machines.json';


export async function getStaticPaths() {
  return machinesData.map(machine => ({
    params: { slug: machine.id },
    props: { machine },
  }));
}

const { machine } = Astro.props;

const folder = machine.folder || "Easy";
const githubRawBase = "https://raw.githubusercontent.com/DiogoCoutoooo/Cybersec-Obsidian/main/Tought%20Process";
const writeupUrl = `${githubRawBase}/${folder}/${machine.title}.md`;

let content = "";
let error = null;
let headings: { depth: number; text: string; id: string }[] = [];

try {
  const response = await fetch(writeupUrl);
  if (response.ok) {
    const rawMarkdown = await response.text();
    
    const parts = rawMarkdown.split(/^---$/m);
    const hasFrontmatter = rawMarkdown.trimStart().startsWith('---');
    
    let processedMarkdown = rawMarkdown;

    if (hasFrontmatter) {
      if (parts.length >= 4) {
        processedMarkdown = parts.slice(3).join('---').trim();
      } else if (parts.length >= 3) {
        processedMarkdown = parts.slice(2).join('---').trim();
      }
    } else {
      if (parts.length >= 2) {
        processedMarkdown = parts.slice(1).join('---').trim();
      }
    }

    // Handle Obsidian-style Wikilinks for images: ![[image.png]]
    processedMarkdown = processedMarkdown.replace(/!\[\[(.*?)\]\]/g, (match, filename) => {
      // Images are in the common "!Media" folder
      const imageUrl = `${githubRawBase}/!Media/${encodeURIComponent(filename.trim())}`;
      return `![${filename}](${imageUrl})`;
    });

    // Also handle standard relative images: ![alt](image.png)
    processedMarkdown = processedMarkdown.replace(/!\[(.*?)\]\((?!(?:https?:\/\/|\/))(.*?)\)/g, (match, alt, path) => {
      const imageUrl = `${githubRawBase}/!Media/${encodeURIComponent(path.trim())}`;
      return `![${alt}](${imageUrl})`;
    });

    const { Marked } = await import('marked');
    const markedInstance = new Marked();

    const { codeToHtml } = await import('shiki');
    
    markedInstance.use({
      async walkTokens(token) {
        if (token.type === 'code') {
          const lang = token.lang || 'bash';
          try {
            token.text = await codeToHtml(token.text, {
              lang: lang,
              theme: 'github-dark'
            });
            (token as any).isHighlighted = true;
          } catch (e) {
            console.error(`Shiki error for lang [${lang}]:`, e);
            (token as any).isHighlighted = false;
          }
        }
      },
      renderer: {
        code(token: any) {
          if (token.isHighlighted) {
            return token.text;
          }
          return `<pre><code class="language-${token.lang}">${token.text}</code></pre>`;
        },
        heading(token: any) {
          // Simple ID generation
          const id = token.text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          headings.push({ depth: token.depth, text: token.text, id });
          return `<h${token.depth} id="${id}">${token.text}</h${token.depth}>`;
        }
      }
    });

    content = await markedInstance.parse(processedMarkdown, { async: true });
  } else {
    error = `Falha ao carregar o writeup: ${response.status} ${response.statusText}`;
    console.error(`Error fetching ${writeupUrl}:`, response.status);
  }
} catch (e) {
  error = "Erro de conexão ao carregar o writeup.";
  console.error(e);
}
---

<HTBLayout 
  title={machine.title}
  os={machine.os}
  difficulty={machine.difficulty}
  pwnedDate={machine.pwnedDate}
  avatar={machine.avatar}
  status={machine.status}
  id={machine.id}
  headings={headings}
  description={machine.description}
>
  {error ? (
    <div class="error-box">
      <p>// {error}</p>
      <p>URL tentada: <a href={writeupUrl} target="_blank">{writeupUrl}</a></p>
    </div>
  ) : (
    <div class="markdown-content" set:html={content} />
  )}
</HTBLayout>

<style>
  .error-box {
    background: #131313;
    border: 1px solid #e74c3c;
    padding: 20px;
    border-radius: 4px;
    color: #e74c3c;
    font-family: 'JetBrains Mono', monospace;
    margin: 40px 0;
  }
  .error-box a {
    color: #fff;
    text-decoration: underline;
  }
  
  .markdown-content {
      color: rgba(255, 255, 255, 0.9);
  }
</style>
